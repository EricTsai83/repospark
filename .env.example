# Local `.env` values for the frontend only.
# `npx convex dev` will usually write `CONVEX_DEPLOYMENT` and `VITE_CONVEX_URL` for you.
VITE_WORKOS_CLIENT_ID=YOUR-WORKOS-CLIENT-ID
VITE_WORKOS_REDIRECT_URI=http://localhost:5173/callback
VITE_CONVEX_URL=your-convex-url

# Convex backend env vars.
# Set these with `npx convex env set ...` or in the Convex dashboard.
# Documented here for reference only; do not keep them in `.env`.
# `WORKOS_CLIENT_ID` is intentionally separate from `VITE_WORKOS_CLIENT_ID`:
# the `VITE_` version is exposed to the browser, while `WORKOS_CLIENT_ID`
# is read by `convex/auth.config.ts`.
# WORKOS_CLIENT_ID=YOUR-WORKOS-CLIENT-ID
# WORKOS_API_KEY=YOUR-WORKOS-API-KEY
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_MODEL=gpt-4o-mini
# DAYTONA_API_KEY=your-daytona-api-key
# DAYTONA_API_URL=https://app.daytona.io/api
# DAYTONA_TARGET=
# DAYTONA_AUTO_STOP_MINUTES=30
# DAYTONA_AUTO_ARCHIVE_MINUTES=1440
# DAYTONA_AUTO_DELETE_MINUTES=2880
# DAYTONA_CPU_LIMIT=2
# DAYTONA_MEMORY_GIB=4
# DAYTONA_DISK_GIB=20
# DAYTONA_NETWORK_ALLOW_LIST=
